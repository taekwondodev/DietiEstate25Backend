# Dockerfile per eseguire i test di sicurezza
# Build stage con Maven e Java 21
FROM maven:3.9-eclipse-temurin-21

# Imposta la directory di lavoro
WORKDIR /app

# Copia il file pom.xml
COPY pom.xml .

# Scarica le dipendenze Maven
RUN mvn dependency:go-offline

# Copia il codice sorgente
COPY src ./src

# Comando di default per eseguire i test
# Può essere overridato da docker-compose o da CLI
# Esempi:
# - Tutti i test: mvn clean test
# - Solo test di sicurezza: mvn clean test -Dtest='com.dietiestate25backend.security.**'
# - Solo test specifico: mvn clean test -Dtest='NomeTest'

CMD ["mvn", "clean", "test"]
